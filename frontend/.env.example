# Frontend env (.env)
# --------------------------------------------------------------------
# VITE_API_BASE — base URL for backend API.
# In dev: leave blank; vite.config.js proxies /api/* to localhost:5000.
# In prod (Vercel/Netlify): set this to your deployed backend URL,
# e.g. https://rentbridge-api.onrender.com
# --------------------------------------------------------------------

VITE_API_BASE=
