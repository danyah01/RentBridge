# ====================================================================
# RentBridge Backend — Environment Variables
# ====================================================================
# COPY this file to ".env" and fill in your real values.
# NEVER commit the real .env file to GitHub. (.gitignore handles this.)
# ====================================================================

# Server port (Render/Railway/Heroku will inject their own PORT — that's fine)
PORT=5000

# Node environment: "development" or "production"
NODE_ENV=development

# MongoDB connection string. For Atlas, it looks like:
# mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rentbridge?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/rentbridge

# JWT secret — keep this LONG and RANDOM. Used to sign auth tokens.
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS — the deployed frontend URL(s) allowed to call this API.
# Comma-separated for multiple origins. Use "*" only during early development.
CORS_ORIGIN=http://localhost:5173

# Bcrypt cost factor. 10 is the standard. Higher = slower but more secure.
BCRYPT_SALT_ROUNDS=10

# Suspicious transaction thresholds (used by suspiciousRules.js).
# These are configurable so the rules can be tuned without code changes.
SUSPICIOUS_LARGE_AMOUNT=100000
SUSPICIOUS_RAPID_COUNT=5
SUSPICIOUS_RAPID_WINDOW_MINUTES=10
